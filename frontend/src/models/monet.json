  "color_strategy": { "type": "multi_sector", "sectors": 10, "chromatic_circle": true, "mood_tinting": true, "gradient_stops_min": 4, "gradient_stops_max": 8, "blend_mode": "screen" },
  "animation_strategy": { "rotation": false, "pulse": true, "pulse_factor": 0.015, "beat_sync": true, "shimmer": true, "shimmer_factor": 0.02 },
