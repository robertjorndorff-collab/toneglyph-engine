    "lighting.rim": "cas.lighting.rim_light_intensity",
    "motion.spin": "cas.motion.spin_rate",
    "motion.pulse": "cas.motion.pulse_amplitude",
    "motion.flutter": "cas.motion.flutter_frequency",
